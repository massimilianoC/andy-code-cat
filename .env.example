NODE_ENV=development
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=30d
AUTH_BYPASS_EMAIL_VERIFICATION=true
MONGODB_URI=mongodb://mongodb:27017/andy-code-cat
MONGODB_DB_NAME=andy-code-cat
REDIS_URL=redis://redis:6379
API_PORT=4000
WEB_PORT=8081
NEXT_PUBLIC_API_URL=http://localhost:4000
MONGO_EXTERNAL_PORT=27018
LLM_CATALOG_SOURCE=env
LLM_AUTO_SEED_ON_STARTUP=true
LLM_DEFAULT_PROVIDER=siliconflow
LLM_CONTEXT_MAX_CHARS=64000
LLM_ARTIFACT_CONTEXT_MAX_CHARS=16000
LLM_MAX_HISTORY_MESSAGES=12
LLM_HISTORY_MESSAGE_MAX_CHARS=2000
LLM_DEFAULT_MAX_COMPLETION_TOKENS=167000
LLM_MAX_COMPLETION_TOKENS=167000
# --- Section-aware focus context (experimental, backward-compatible) ---
# Enable to send only the containing section's HTML in focused-edit mode instead of full page.
# Reduces token usage by 40-60% for focused edits. Disable to use original full-artifact path.
LLM_FOCUS_SECTION_CONTEXT=true
# Max chars for the section HTML sent in section-context mode (default: 8000)
LLM_FOCUS_SECTION_HTML_MAX_CHARS=8000
# History strategy in section-context mode: full | user_only | none (default: none)
LLM_FOCUS_HISTORY_MODE=user_only
LMSTUDIO_BASE_URL=http://localhost:1234/v1
SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1
SILICONFLOW_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter API key — get one at https://openrouter.ai/keys
# Free models (model ids ending in :free) work without credits.
# Paid models require a funded account.
OPEN_ROUTER_API_KEY=
LLM_PROVIDER_API_KEYS_JSON=

COST_POLICY_TEXT_EUR_PER_1K_TOKENS=0.005
COST_POLICY_IMAGE_EUR_PER_ASSET=0.1
COST_POLICY_VIDEO_EUR_PER_ASSET=0.2
# When the provider (e.g. OpenRouter) reports the actual USD cost, it is used instead of the flat rate above.
# These two settings control the USD→EUR conversion and an optional safety markup (+10% default).
COST_POLICY_USD_TO_EUR_RATE=0.92
COST_POLICY_PROVIDER_MARKUP_FACTOR=1.1

# --- File storage & export ---
# DATA_DIR: absolute path to data directory.
# Docker: leave unset — defaults to /workspace/data (monorepo root /data when mounted at ./data:/workspace/data)
# Local dev: leave unset — auto-resolved to {monorepo-root}/data
# DATA_DIR=/data
EXPORT_JWT_SECRET=change-me-export-jwt-secret-min32chars!!
EXPORT_DOWNLOAD_TTL=3600
UPLOAD_MAX_SIZE_BYTES=20971520

# --- Publishing domain (hybrid path + subdomain model) ---
# Set to the base domain when nginx wildcard is active.
# When set, each published site gets a subdomain URL alongside the path URL:
#   path URL:      http://api.yourdomain.com/p/{publishId}
#   subdomain URL: http://{publishId}.yourdomain.com
# Leave unset in local dev — only path-based URL is returned.
# PUBLIC_DOMAIN=yourdomain.com

# CORS: comma-separated list of allowed origins for the API.
# Use "*" for local dev (default). In production, set to the web app origin.
CORS_ORIGIN=*

# --- Next.js public API URL ---
# In production with nginx: set to the public API subdomain.
# Built into the Next.js bundle at build time (NEXT_PUBLIC_* vars).
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

