NODE_ENV=development
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=30d
# Keep true until the email delivery and verification flow is production-ready.
# Set to false only after verification send/retry/observe flows are fully validated.
AUTH_BYPASS_EMAIL_VERIFICATION=true
MONGODB_URI=mongodb://mongodb:27017/andy-code-cat
MONGODB_DB_NAME=andy-code-cat
REDIS_URL=redis://redis:6379
API_PORT=4000
WEB_PORT=8081
NEXT_PUBLIC_API_URL=http://localhost:4000
# Public API base URL written INTO persisted artifact HTML when stock images are downloaded and saved as project assets.
# This URL is embedded in the saved HTML as /p/media/:assetId and must be reachable by end-user browsers.
#
# LOCAL DEV (default — direct API port):
#   PUBLIC_API_BASE_URL=http://localhost:4000
#   Works because port 4000 is exposed in docker-compose.yml.
#   Images appear in the preview iframe because the browser can reach localhost:4000 directly.
#
# LOCAL DEV via nginx (recommended — use the nginx front-door on port 80):
#   PUBLIC_API_BASE_URL=http://localhost
#   Use this if you access the app exclusively through http://localhost (port 80).
#   The nginx config proxies /p/* to the API so asset URLs resolve correctly.
#
# PRODUCTION (domain mode — install.sh sets this automatically):
#   PUBLIC_API_BASE_URL=https://api.yourdomain.com
#
# WARNING: if PUBLIC_API_BASE_URL points to a host/port that end-user browsers cannot reach,
# stock images saved as project assets will appear as broken images in the preview and in
# published sites. Always verify the URL is accessible from the browser that opens the workspace.
PUBLIC_API_BASE_URL=http://localhost:4000
MONGO_EXTERNAL_PORT=27018
LLM_CATALOG_SOURCE=env
LLM_AUTO_SEED_ON_STARTUP=true
LLM_DEFAULT_PROVIDER=siliconflow
LLM_CONTEXT_MAX_CHARS=64000
LLM_ARTIFACT_CONTEXT_MAX_CHARS=16000
LLM_MAX_HISTORY_MESSAGES=12
LLM_HISTORY_MESSAGE_MAX_CHARS=2000
LLM_DEFAULT_MAX_COMPLETION_TOKENS=167000
LLM_MAX_COMPLETION_TOKENS=167000
# --- Section-aware focus context (experimental, backward-compatible) ---
# Enable to send only the containing section's HTML in focused-edit mode instead of full page.
# Reduces token usage by 40-60% for focused edits. Disable to use original full-artifact path.
LLM_FOCUS_SECTION_CONTEXT=true
# Max chars for the section HTML sent in section-context mode (default: 8000)
LLM_FOCUS_SECTION_HTML_MAX_CHARS=8000
# History strategy in section-context mode: full | user_only | none (default: none)
LLM_FOCUS_HISTORY_MODE=user_only
LMSTUDIO_BASE_URL=http://localhost:1234/v1
SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1
SILICONFLOW_API_KEY=
SILICONFLOW_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
SILICONFLOW_IMAGE_SIZE=1024x1024
SILICONFLOW_IMAGE_STEPS=4
SILICONFLOW_IMAGE_TIMEOUT_MS=45000
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter API key — get one at https://openrouter.ai/keys
# Free models (model ids ending in :free) work without credits.
# Paid models require a funded account.
OPEN_ROUTER_API_KEY=
LLM_PROVIDER_API_KEYS_JSON=

COST_POLICY_TEXT_EUR_PER_1K_TOKENS=0.005
COST_POLICY_IMAGE_EUR_PER_ASSET=0.1
COST_POLICY_VIDEO_EUR_PER_ASSET=0.2
# When the provider (e.g. OpenRouter) reports the actual USD cost, it is used instead of the flat rate above.
# These two settings control the USD→EUR conversion and an optional safety markup (+10% default).
COST_POLICY_USD_TO_EUR_RATE=0.92
COST_POLICY_PROVIDER_MARKUP_FACTOR=1.1

# --- File storage & export ---
# DATA_DIR: absolute path to data directory.
# Docker: leave unset — defaults to /workspace/data (monorepo root /data when mounted at ./data:/workspace/data)
# Local dev: leave unset — auto-resolved to {monorepo-root}/data
# DATA_DIR=/data
# STORAGE_ADAPTER: installation-level default. User-level BYOS override can be layered later.
# local | minio
STORAGE_ADAPTER=local
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=andy-code-cat-media
MINIO_REGION=us-east-1
MINIO_ROOT_PREFIX=andy-code-cat
MEDIA_AUTO_CLASSIFY_UPLOADS=true
MEDIA_CLASSIFIER_MODEL=heuristic-media-classifier-v1
EXPORT_JWT_SECRET=change-me-export-jwt-secret-min32chars!!
EXPORT_DOWNLOAD_TTL=3600
UPLOAD_MAX_SIZE_BYTES=20971520

# --- Publishing domain (hybrid path + subdomain model) ---
# Set to the base domain when nginx wildcard is active.
# When set, each published site gets a subdomain URL alongside the path URL:
#   path URL:      http://api.yourdomain.com/p/{publishId}
#   subdomain URL: http://{publishId}.yourdomain.com
# Leave unset in local dev — only path-based URL is returned.
# PUBLIC_DOMAIN=yourdomain.com

# CORS: comma-separated list of allowed origins for the API.
# Use "*" for local dev (default). In production, set to the web app origin.
CORS_ORIGIN=*

# --- Super Admin seed credentials ---
# The seed script (npm run seed) creates a superadmin account with these credentials.
# SUPERADMIN_PASSWORD must be set explicitly — no insecure default. Leave blank to skip superadmin creation.
SUPERADMIN_EMAIL=superadmin@andy-code-cat.local
SUPERADMIN_PASSWORD=

# --- Next.js public API URL ---
# In production with nginx: set to the public API subdomain.
# Built into the Next.js bundle at build time (NEXT_PUBLIC_* vars).
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com



# --- Document Context Layer (DCL) enrichment ---
# Master switch — false disables all enrichment. Upload still works normally.
ENRICHMENT_ENABLED=true
# Document text extraction (PDF, DOCX, TXT, MD)
ENRICHMENT_DOCUMENT_PARSING=true
# LLM pass for DocumentBrief (requires ENRICHMENT_DOCUMENT_PARSING=true)
ENRICHMENT_DOCUMENT_LLM_PASS=true
ENRICHMENT_TEXT_PROVIDER=siliconflow
ENRICHMENT_TEXT_MODEL=Qwen/Qwen2.5-72B-Instruct
# Vision model analysis for image assets
ENRICHMENT_IMAGE_ANALYSIS=true
ENRICHMENT_VISION_PROVIDER=siliconflow
ENRICHMENT_VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct
# Layer D injection into generation prompts
ENRICHMENT_INJECT_LAYER_D=true
ENRICHMENT_LAYER_D_MAX_CHARS=21000
ENRICHMENT_LAYER_D_MAX_ASSETS=5

# --- VibeCore pipeline flags ---
# Layer Φ: intent & format classifier (runs before project creation from dashboard)
VIBE_CLASSIFIER_ENABLED=true
# Layer Ω: prompt optimizer (runs before classifier)
VIBE_OPTIMIZER_ENABLED=true

# --- External image service API keys ---
# Used by the stock-image resolver during artifact generation.
# Resolution order (default policy): Pexels → Pixabay → Unsplash → LoremFlickr → Picsum
# Keys can also be stored encrypted in MongoDB via Admin → Integration Hub (DB keys take priority over env vars).
#
# IMPORTANT: at least one key (or LoremFlickr/Picsum fallback) is required for stock images to appear.
# Without any key the orchestrator falls through to LoremFlickr (no-key provider) automatically.
# LoremFlickr images are low-quality placeholders — add at least one real key for production use.
#
# The active provider and fallback chain are configurable per-deployment via:
#   Admin dashboard → Integration Hub → "Stock provider policy" card
# or via PATCH /v1/admin/config with { mediaProviderPolicy: { stockImage: { ... } } }
#
# If true, artifact generation fails when a resolved stock image cannot be downloaded and saved.
# Default false: images that fail to download are skipped (placeholder left in HTML) and notified to the user.
IMAGE_STOCK_PERSIST_STRICT=false
# Pexels: https://www.pexels.com/api/ (200 req/h, free tier)
PEXELS_API_KEY=
# Pixabay: https://pixabay.com/api/docs/ (100 req/min, free, CC0 licensed)
PIXABAY_API_KEY=
# Unsplash: https://unsplash.com/developers (50 req/h free tier)
UNSPLASH_ACCESS_KEY=
