# =============================================================================
# andy-code-cat — Environment for PRODUCTION deploy
# =============================================================================
# Copy this file to .env.deploy on your server and fill in real values.
# .env.deploy (and all .env.*) are gitignored — NEVER commit them.
#
# Quick setup:
#   cp .env.deploy.example .env.deploy
#   # edit .env.deploy with your real values
#   docker compose -f docker-compose.deploy.yml --env-file .env.deploy up -d
# =============================================================================

NODE_ENV=production

# --- JWT secrets (generate with: openssl rand -hex 32) ---
JWT_ACCESS_SECRET=CHANGE_ME_STRONG_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_STRONG_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=30d

# Set to "true" only to bypass email verification temporarily during first deploy.
AUTH_BYPASS_EMAIL_VERIFICATION=false

# --- MongoDB & Redis (Docker internal — do NOT change) ---
MONGODB_URI=mongodb://mongodb:27017/andy-code-cat
MONGODB_DB_NAME=andy-code-cat
REDIS_URL=redis://redis:6379

# --- Ports ---
API_PORT=4000
WEB_PORT=8081
MONGO_EXTERNAL_PORT=27018

# --- CORS ---
# Restrict to your web app origin. No trailing slash.
CORS_ORIGIN=https://app.yourdomain.com

# --- Public domain for subdomain publishing ---
# Used to construct {slug}.yourdomain.com URLs for published sites.
# Leave unset in local dev.
PUBLIC_DOMAIN=yourdomain.com

# --- Next.js public API URL ---
# BAKED INTO the Next.js bundle at build time (NEXT_PUBLIC_* vars).
# Must match the public API subdomain served by nginx.
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# --- LLM ---
LLM_CATALOG_SOURCE=env
LLM_AUTO_SEED_ON_STARTUP=true
LLM_DEFAULT_PROVIDER=siliconflow
LLM_CONTEXT_MAX_CHARS=64000
LLM_ARTIFACT_CONTEXT_MAX_CHARS=16000
LLM_MAX_HISTORY_MESSAGES=12
LLM_HISTORY_MESSAGE_MAX_CHARS=2000
LLM_DEFAULT_MAX_COMPLETION_TOKENS=167000
LLM_MAX_COMPLETION_TOKENS=167000
LLM_FOCUS_SECTION_CONTEXT=true
LLM_FOCUS_SECTION_HTML_MAX_CHARS=8000
LLM_FOCUS_HISTORY_MODE=user_only

# --- LLM Provider API keys ---
# SiliconFlow: https://siliconflow.cn/account/api-keys
SILICONFLOW_BASE_URL=https://api.siliconflow.com/v1
SILICONFLOW_API_KEY=YOUR_SILICONFLOW_API_KEY_HERE

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPEN_ROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# LM Studio (local inference — not available in production)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# --- Cost policy ---
COST_POLICY_TEXT_EUR_PER_1K_TOKENS=0.005
COST_POLICY_IMAGE_EUR_PER_ASSET=0.1
COST_POLICY_VIDEO_EUR_PER_ASSET=0.2
COST_POLICY_USD_TO_EUR_RATE=0.92
COST_POLICY_PROVIDER_MARKUP_FACTOR=1.1

# --- Storage & export (generate with: openssl rand -hex 32) ---
EXPORT_JWT_SECRET=CHANGE_ME_EXPORT_SECRET_MIN32CHARS_DIFFERENT_FROM_JWT
EXPORT_DOWNLOAD_TTL=3600
UPLOAD_MAX_SIZE_BYTES=20971520
