ke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" stroke-width=\\\"2\\\" d=\\\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\\\"></path></svg>\\n            Perchè Sceglierci\\n          </h3>\\n          <div class=\\\"flex flex-wrap gap-3 mb-8\\\" data-pf-id=\\\"benefits-pills\\\">\\n            <span class=\\\"px-4 py-1.5 rounded-full bg-indigo-100 text-indigo-700 text-sm font-semibold\\\">Try Before Buy</span>\\n            <span class=\\\"px-4 py-1.5 rounded-full bg-green-100 text-green-700 text-sm font-semibold\\\">1€ - 5€ Max</span>\\n            <span class=\\\"px-4 py-1.5 rounded-full bg-orange-100 text-orange-700 text-sm font-semibold\\\">White Label</span>\\n          </div>\\n          \\n          <!-- Razzo Animato -->\\n          <div class=\\\"relative h-32 flex items-center justify-center\\\" data-pf-id=\\\"rocket-container\\\">\\n            <div class=\\\"absolute bottom-0 w-full h-px bg-slate-200\\\" data-pf-id=\\\"ground-line\\\"></div>\\n            <svg id=\\\"rocket-icon\\\" class=\\\"w-16 h-16 text-indigo-600 absolute bottom-2\\\" fill=\\\"none\\\" stroke=\\\"currentColor\\\" viewBox=\\\"0 0 24 24\\\" stroke-width=\\\"1.5\\\">\\n              <path stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\" d=\\\"M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z\\\"></path>\\n            </svg>\\n            <div class=\\\"absolute bottom-1 w-2 h-2 bg-orange-500 rounded-full opacity-0\\\" id=\\\"rocket-flame\\\"></div>\\n          </div>\\n          <p class=\\\"text-center text-sm text-slate-500 font-medium mt-2\\\">Launch in pochi secondi!</p>\\n        </div>\\n      </div>\\n    </div>\\n  </section>\\n  \\n  <script>\\n    // Animazione del Razzo\\n    document.addEventListener('DOMContentLoaded', () => {\\n      const rocket = document.getElementById('rocket-icon');\\n      const flame = document.getElementById('rocket-flame');\\n      \\n      if(rocket) {\\n        // Reset posizione iniziale\\n        gsap.set(rocket, { y: 0, rotation: 0 });\\n        \\n        // Timeline animazione\\n        const tl = gsap.timeline({ repeat: -1, repeatDelay: 2 });\\n        \\n        tl.to(rocket, {\\n          duration: 0.5,\\n          scale: 1.2,\\n          yoyo: true,\\n          repeat: 1,\\n          ease: 'power1.inOut'\\n        })\\n        .to(rocket, {\\n          duration: 1.5,\\n          y: -100,\\n          ease: 'power1.out',\\n          onStart: () => { gsap.to(flame, { opacity: 1, scale: 1.5, duration: 0.2 }); }\\n        }, '>0.2')\\n        .to(rocket, {\\n          duration: 1,\\n          opacity: 0,\\n          ease: 'power1.in'\\n        }, '>-0.5')\\n        .to(rocket, {\\n          duration: 0.1,\\n          y: 0,\\n          opacity: 1,\\n          onComplete: () => { gsap.to(flame, { opacity: 0, scale: 1, duration: 0.1 }); }\\n        });\\n      }\\n    });\\n  </script>\"\n  }\n}",
