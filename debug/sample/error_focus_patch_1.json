newsletter' class='text-sm text-slate-600'>Vorrei ricevere aggiornamenti su nuove funzionalità AI.</label>\\n        </div>\\n        <button type='submit' class='w-full btn-primary text-white py-3 rounded-lg font-bold text-lg'>Invia Messaggio</button>\\n      </form>\\n    </div>\\n  </section>\\n\\n  <footer class='bg-slate-900 text-slate-400 py-12 border-t border-slate-800'>\\n    <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6'>\\n      <div class='flex items-center gap-2'>\\n        <i data-lucide='sparkles' class='text-indigo-500 w-6 h-6'></i>\\n        <span class='font-bold text-lg text-white'>AppBuilder<span class='text-indigo-500'>AI</span></span>\\n      </div>\\n      <div class='flex space-x-6'>\\n        <a href='#' class='hover:text-white transition'>Privacy Policy</a>\\n        <a href='#' class='hover:text-white transition'>Termini di Servizio</a>\\n        <a href='#' class='hover:text-white transition'>Contatti</a>\\n      </div>\\n      <div class='text-sm'>\\n        &copy; 2023 AppBuilder AI. Tutti i diritti riservati.\\n      </div>\\n    </div>\\n  </footer>\\n\\n  <script>\\n    // Inizializza icone\\n    lucide.createIcons();\\n\\n    // Animazioni GSAP\\n    gsap.registerPlugin(ScrollTrigger);\\n\\n    gsap.from('nav', { opacity: 0, y: -20, duration: 0.8 });\\n    gsap.from('section h1, section p, section button', { \\n      opacity: 0, \\n      y: 30, \\n      duration: 0.8, \\n      stagger: 0.2,\\n      delay: 0.2\\n    });\\n    gsap.from('.feature-card', {\\n      scrollTrigger: {\\n        trigger: '#features',\\n        start: 'top center'\\n      },\\n      opacity: 0,\\n      y: 50,\\n      duration: 0.6,\\n      stagger: 0.1\\n    });\\n    gsap.from('#how-it-works .relative', {\\n      scrollTrigger: {\\n        trigger: '#how-it-works',\\n        start: 'top center'\\n      },\\n      opacity: 0,\\n      scale: 0.9,\\n      duration: 0.5,\\n      stagger: 0.2\\n    });\\n\\n    // Precompilazione email (simulata per demo)\\n    // In un ambiente reale, questo potrebbe essere popolato dall'SDK del provider di email\\n    document.addEventListener('DOMContentLoaded', () => {\\n      const emailInput = document.getElementById('contact-email');\\n      // Esempio: se l'utente ha un cookie o è loggato, qui si precompilerebbe\\n      // emailInput.value = 'user@example.com'; \\n    });\\n  </script>\\n</body>\\n</html>\",\n    \"css\": \"body { font-family: 'Inter', sans-serif; }\\n.gradient-text { background: linear-gradient(135deg, #6366f1, #a855f7, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }\\n.glass-panel { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.2); }\\n.btn-primary { background: linear-gradient(135deg, #6366f1, #a855f7); transition: all 0.3s ease; }\\n.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(168, 85, 247, 0.4); }\\n.feature-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }\\n.feature-card:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); }\\n.nav-link { position: relative; }\\n.nav-link::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 2px; background: #a855f7; transition: width 0.3s ease; }\\n.nav-link:hover::after { width: 100%; }\",\n    \"js\": \"// Inizializza icone\\nlucide.createIcons();\\n\\n// Animazioni GSAP\\n// Nota: ScrollTrigger è incluso in GSAP 3 di default, ma se usato in produzione assicurarsi di caricare il plugin se necessario.\\ngsap.from('nav', { opacity: 0, y: -20, duration: 0.8 });\\ngsap.from('section h1, section p, section button', { \\n  opacity: 0, \\n  y: 30, \\n  duration: 0.8, \\n  stagger: 0.2,\\n  delay: 0.2\\n});\\ngsap.from('.feature-card', {\\n  scrollTrigger: {\\n    trigger: '#features',\\n    start: 'top center'\\n  },\\n  opacity: 0,\\n  y: 50,\\n  duration: 0.6,\\n  stagger: 0.1\\n});\\ngsap.from('#how-it-works .relative', {\\n  scrollTrigger: {\\n    trigger: '#how-it-works',\\n    start: 'top center'\\n  },\\n  opacity: 0,\\n  scale: 0.9,\\n  duration: 0.5,\\n  stagger: 0.2\\n});\\n\\n// Precompilazione email (simulata per demo)\\n// In un ambiente reale, questo potrebbe essere popolato dall'SDK del provider di email\\n// Esempio: se l'utente ha un cookie o è loggato, qui si precompilerebbe\\n// document.getElementById('contact-email').value = 'user@example.com';\"\n  }\n}",
