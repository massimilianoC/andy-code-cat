                    "html": "<!DOCTYPE html><html lang=\"it\"><head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>PromptForge - AI App Builder</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script defer=\"\" src=\"https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js\"></script>\n  <script src=\"https://unpkg.com/lucide@latest/dist/umd/lucide.min.js\"></script>\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/aos@2/dist/aos.css\">\n  <script src=\"https://cdn.jsdelivr.net/npm/aos@2/dist/aos.js\"></script>\n  <style>\n    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');\n\n    * {\n      font-family: 'Outfit', sans-serif;\n    }\n\n    .gradient-text {\n      background: linear-gradient(135deg, #6366f1 0%, #a855f7 50%, #ec4899 100%);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n    }\n\n    .gradient-bg {\n      background: linear-gradient(135deg, #6366f1 0%, #a855f7 50%, #ec4899 100%);\n    }\n\n    .glass {\n      background: rgba(255, 255, 255, 0.05);\n      backdrop-filter: blur(20px);\n      border: 1px solid rgba(255, 255, 255, 0.1);\n    }\n\n    .glow {\n      box-shadow: 0 0 60px rgba(168, 85, 247, 0.3);\n    }\n\n    .float {\n      animation: float 6s ease-in-out infinite;\n    }\n\n    @keyframes float {\n\n      0%,\n      100% {\n        transform: translateY(0);\n      }\n\n      50% {\n        transform: translateY(-20px);\n      }\n    }\n\n    .pulse-ring {\n      animation: pulse-ring 2s cubic-bezier(0.455, 0.03, 0.515, 0.955) infinite;\n    }\n\n    @keyframes pulse-ring {\n      0% {\n        transform: scale(0.8);\n        opacity: 1;\n      }\n\n      100% {\n        transform: scale(1.4);\n        opacity: 0;\n      }\n    }\n\n    .grid-pattern {\n      background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.1) 1px, transparent 0);\n      background-size: 40px 40px;\n    }\n  </style>\n</head>\n\n<body class=\"bg-slate-950 text-white overflow-x-hidden\">\n  <!-- Navigation -->\n  <nav class=\"fixed top-0 left-0 right-0 z-50 glass\" x-data=\"{ mobile: false }\">\n    <div class=\"max-w-7xl mx-auto px-6 py-4 flex items-center justify-between\">\n      <div class=\"flex items-center gap-2\">\n        <div class=\"w-10 h-10 gradient-bg rounded-xl flex items-center justify-center\">\n          <i data-lucide=\"zap\" class=\"w-6 h-6 text-white\"></i>\n        </div>\n        <span class=\"text-xl font-bold\">PromptForge</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8\">\n        <a href=\"#features\" class=\"text-slate-300 hover:text-white transition\">Funzionalità</a>\n        <a href=\"#pricing\" class=\"text-slate-300 hover:text-white transition\">Prezzi</a>\n        <a href=\"#whitelabel\" class=\"text-slate-300 hover:text-white transition\">White Label</a>\n        <a href=\"#contact\" class=\"gradient-bg px-5 py-2 rounded-full font-medium hover:opacity-90 transition\">Contattaci</a>\n      </div>\n      <button @click=\"mobile=!mobile\" class=\"md:hidden\">\n        <i data-lucide=\"menu\" class=\"w-6 h-6\"></i>\n      </button>\n    </div>\n    <div x-show=\"mobile\" class=\"md:hidden px-6 pb-4 flex flex-col gap-4\">\n      <a href=\"#features\" class=\"text-slate-300\">Funzionalità</a>\n      <a href=\"#pricing\" class=\"text-slate-300\">Prezzi</a>\n      <a href=\"#whitelabel\" class=\"text-slate-300\">White Label</a>\n    </div>\n  </nav>\n\n  <!-- Hero -->\n  <section class=\"min-h-screen flex items-center justify-center relative grid-pattern pt-20\">\n    <div class=\"absolute inset-0 bg-gradient-to-b from-slate-950 via-transparent to-slate-950\"></div>\n    <div class=\"max-w-5xl mx-auto px-6 text-center relative z-10\" data-aos=\"fade-up\">\n      <div class=\"inline-flex items-center gap-2 glass px-4 py-2 rounded-full mb-8\">\n        <span class=\"w-2 h-2 bg-green-400 rounded-full animate-pulse\"></span>\n        <span class=\"text-sm text-slate-300\">✨ AI-Powered Builder</span>\n      </div>\n      <h1 class=\"text-5xl md:text-7xl font-extrabold mb-6 leading-tight\">\n        Crea il tuo sito in <span class=\"gradient-text\">30 secondi</span><br>\n        con il potere dell'AI\n      </h1>\n      <p class=\"text-xl text-slate-400 mb-10 max-w-2xl mx-auto\">\n        Descrivi cosa vuoi e l'AI costruisce la tua landing page one-scroll. <br>\n        <span class=\"text-purple-400\">Try before you buy</span> — vedi il risultato, poi decidi se pagare!\n      </p>\n      <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4\">\n        <a href=\"#contact\" class=\"gradient-bg px-8 py-4 rounded-full font-bold text-lg hover:glow transition-all transform hover:scale-105 flex items-center gap-2\">\n          <i data-lucide=\"rocket\" class=\"w-5 h-5\"></i>\n          Inizia Gratis\n        </a>\n        <div x-data=\"{ open: false, selected: null }\" class=\"relative\">\n          <button @click=\"open=!open\" class=\"glass px-8 py-4 rounded-full font-medium hover:bg-white/10 transition flex items-center gap-2\">\n            <i data-lucide=\"sparkles\" class=\"w-5 h-5 text-purple-400\"></i>\n            <span x-text=\"selected ? selected : 'Scegli il tuo progetto'\"></span>\n            <i data-lucide=\"chevron-down\" class=\"w-4 h-4\" :class=\"{'rotate-180': open}\"></i>\n          </button>\n          <div x-show=\"open\" @click.away=\"open=false\" x-transition:enter=\"transition ease-out duration-200\" x-transition:enter-start=\"opacity-0 scale-95\" x-transition:enter-end=\"opacity-100 scale-100\" class=\"absolute top-full mt-2 left-1/2 -translate-x-1/2 w-72 glass rounded-2xl p-2 z-50\">\n            <button @click=\"selected=&quot;Business Website&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center\"><i data-lucide=\"briefcase\" class=\"w-5 h-5 text-blue-400\"></i></div>\n              <div><div class=\"font-medium\">Business Website</div><div class=\"text-xs text-slate-400\">Sito vetrina professionale</div></div>\n            </button>\n            <button @click=\"selected=&quot;Promo Landing&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-pink-500/20 rounded-lg flex items-center justify-center\"><i data-lucide=\"megaphone\" class=\"w-5 h-5 text-pink-400\"></i></div>\n              <div><div class=\"font-medium\">Promo Landing</div><div class=\"text-xs text-slate-400\">Landing per campagne</div></div>\n            </button>\n            <button @click=\"selected=&quot;Casual Game&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center\"><i data-lucide=\"gamepad-2\" class=\"w-5 h-5 text-green-400\"></i></div>\n              <div><div class=\"font-medium\">Casual Game</div><div class=\"text-xs text-slate-400\">Mini gioco interattivo</div></div>\n            </button>\n            <button @click=\"selected=&quot;Branded Event&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-purple-500/20 rounded-lg flex items-center justify-center\"><i data-lucide=\"calendar\" class=\"w-5 h-5 text-purple-400\"></i></div>\n              <div><div class=\"font-medium\">Branded Event</div><div class=\"text-xs text-slate-400\">Sito per evento brandizzato</div></div>\n            </button>\n            <button @click=\"selected=&quot;Portfolio&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-orange-500/20 rounded-lg flex items-center justify-center\"><i data-lucide=\"folder\" class=\"w-5 h-5 text-orange-400\"></i></div>\n              <div><div class=\"font-medium\">Portfolio</div><div class=\"text-xs text-slate-400\">Mostra il tuo lavoro</div></div>\n            </button>\n            <button @click=\"selected=&quot;Restaurant&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-cyan-500/20 rounded-lg flex items-center justify-center\"><i data-lucide=\"utensils\" class=\"w-5 h-5 text-cyan-400\"></i></div>\n              <div><div class=\"font-medium\">Restaurant</div><div class=\"text-xs text-slate-400\">Menu e prenotazioni</div></div>\n            </button>\n          </div>\n        </div>\n      </div>\n      <div class=\"mt-16 flex items-center justify-center gap-8 text-slate-500\">\n        <div class=\"flex items-center gap-2\">\n          <i data-lucide=\"download\" class=\"w-5 h-5\"></i>\n          <span>Scarica ZIP</span>\n        </div>\n        <div class=\"flex items-center gap-2\">\n          <i data-lucide=\"edit-3\" class=\"w-5 h-5\"></i>\n          <span>WYSIWYG Editor</span>\n        </div>\n        <div class=\"flex items-center gap-2\">\n          <i data-lucide=\"euro\" class=\"w-5 h-5\"></i>\n          <span>1-5€ a app</span>\n        </div>\n      </div>\n    </div>\n    <!-- Floating cards -->\n    <div class=\"absolute top-1/4 left-10 glass rounded-2xl p-4 float hidden lg:block\" style=\"animation-delay: 0s;\">\n      <div class=\"text-sm text-slate-400\">Costo</div>\n      <div class=\"text-2xl font-bold text-green-400\">€2.50</div>\n    </div>\n    <div class=\"absolute top-1/3 right-10 glass rounded-2xl p-4 float hidden lg:block\" style=\"animation-delay: 2s;\">\n      <div class=\"text-sm text-slate-400\">Template</div>\n      <div class=\"text-2xl font-bold text-purple-400\">One-Scroll</div>\n    </div>\n  </section>\n\n  <!-- How it works -->\n  <section id=\"how\" class=\"py-24 relative\">\n    <div class=\"max-w-6xl mx-auto px-6\">\n      <div class=\"text-center mb-16\" data-aos=\"fade-up\">\n        <h2 class=\"text-4xl font-bold mb-4\">Semplice come contare fino a 3</h2>\n        <p class=\"text-slate-400\">Il tuo sito pronto in tre mosse</p>\n      </div>\n      <div class=\"grid md:grid-cols-3 gap-8\">\n        <div class=\"glass rounded-3xl p-8 text-center relative\" data-aos=\"fade-up\" data-aos-delay=\"100\">\n          <div class=\"w-16 h-16 gradient-bg rounded-2xl flex items-center justify-center mx-auto mb-6\">\n            <i data-lucide=\"message-square\" class=\"w-8 h-8\"></i>\n          </div>\n          <div class=\"text-5xl font-bold gradient-text mb-2\">1</div>\n          <h3 class=\"text-xl font-semibold mb-3\">Descrivi</h3>\n          <p class=\"text-slate-400\">Raconta cosa vuoi in linguaggio naturale. L'AI capisce e crea.</p>\n        </div>\n        <div class=\"glass rounded-3xl p-8 text-center relative\" data-aos=\"fade-up\" data-aos-delay=\"200\">\n          <div class=\"w-16 h-16 gradient-bg rounded-2xl flex items-center justify-center mx-auto mb-6\">\n            <i data-lucide=\"eye\" class=\"w-8 h-8\"></i>\n          </div>\n          <div class=\"text-5xl font-bold gradient-text mb-2\">2</div>\n          <h3 class=\"text-xl font-semibold mb-3\">Anteprima</h3>\n          <p class=\"text-slate-400\">Vedi il risultato in tempo reale. Modifica con l'editor WYSIWYG.</p>\n        </div>\n        <div class=\"glass rounded-3xl p-8 text-center relative\" data-aos=\"fade-up\" data-aos-delay=\"300\">\n          <div class=\"w-16 h-16 gradient-bg rounded-2xl flex items-center justify-center mx-auto mb-6\">\n            <i data-lucide=\"check-circle\" class=\"w-8 h-8\"></i>\n          </div>\n          <div class=\"text-5xl font-bold gradient-text mb-2\">3</div>\n          <h3 class=\"text-xl font-semibold mb-3\">Scarica</h3>\n          <p class=\"text-slate-400\">Se ti piace, scarica lo ZIP o pubblica. Solo 1-5€!</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Features -->\n  <section id=\"features\" class=\"py-24 bg-slate-900/50\">\n    <div class=\"max-w-6xl mx-auto px-6\">\n      <div class=\"text-center mb-16\" data-aos=\"fade-up\">\n        <h2 class=\"text-4xl font-bold mb-4\">Tutto quello che ti serve</h2>\n        <p class=\"text-slate-400\">Funzionalità AI avanzate in un'unica piattaforma</p>\n      </div>\n      <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-6\">\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"100\">\n          <div class=\"w-12 h-12 bg-purple-500/20 rounded-xl flex items-center justify-center mb-4\">\n            <i data-lucide=\"layout\" class=\"w-6 h-6 text-purple-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">One-Scroll Builder</h3>\n          <p class=\"text-slate-400 text-sm\">Landing page ottimizzate per conversione in un'unica pagina scorrevole.</p>\n        </div>\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"150\">\n          <div class=\"w-12 h-12 bg-pink-500/20 rounded-xl flex items-center justify-center mb-4\">\n            <i data-lucide=\"image\" class=\"w-6 h-6 text-pink-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">AI Image Generator</h3>\n          <p class=\"text-slate-400 text-sm\">Genera immagini uniche con AI direttamente nel builder.</p>\n        </div>\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"200\">\n          <div class=\"w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center mb-4\">\n            <i data-lucide=\"message-circle\" class=\"w-6 h-6 text-blue-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">AI Chatbot</h3>\n          <p class=\"text-slate-400 text-sm\">Integra un chatbot AI che risponde ai tuoi visitatori 24/7.</p>\n        </div>\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"250\">\n          <div class=\"w-12 h-12 bg-green-500/20 rounded-xl flex items-center justify-center mb-4\">\n            <i data-lucide=\"edit-3\" class=\"w-6 h-6 text-green-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">WYSIWYG Editor</h3>\n          <p class=\"text-slate-400 text-sm\">Modifica ogni elemento visivamente. Drag &amp; drop semplice.</p>\n        </div>\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"300\">\n          <div class=\"w-12 h-12 bg-orange-500/20 rounded-xl flex items-center justify-center mb-4\">\n            <i data-lucide=\"code\" class=\"w-6 h-6 text-orange-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">Codice Pulito</h3>\n          <p class=\"text-slate-400 text-sm\">Scarica ZIP con sorgenti HTML/CSS/JS pronti per il deploy.</p>\n        </div>\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"350\">\n          <div class=\"w-12 h-12 bg-cyan-500/20 rounded-xl flex items-center justify-center mb-4\">\n            <i data-lucide=\"plug\" class=\"w-6 h-6 text-cyan-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">Integrazioni</h3>\n          <p class=\"text-slate-400 text-sm\">Collega analytics, email marketing, CRM e molto altro.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Pricing -->\n  <section id=\"pricing\" class=\"py-24 relative\">\n    <div class=\"max-w-4xl mx-auto px-6\">\n      <div class=\"text-center mb-16\" data-aos=\"fade-up\">\n        <h2 class=\"text-4xl font-bold mb-4\">Pay per use</h2>\n        <p class=\"text-slate-400\">Meno di un aperitivo per il tuo sito professionale</p>\n      </div>\n      <div class=\"glass rounded-3xl p-8 md:p-12 text-center glow\" data-aos=\"zoom-in\">\n        <div class=\"inline-flex items-center gap-2 glass px-4 py-2 rounded-full mb-6\">\n          <i data-lucide=\"zap\" class=\"w-4 h-4 text-yellow-400\"></i>\n          <span class=\"text-sm\">Try Before You Buy</span>\n        </div>\n        <div class=\"text-6xl font-bold mb-2\">\n          <span class=\"gradient-text\">€1 - €5</span>\n        </div>\n        <p class=\"text-slate-400 mb-8\">per ogni app creata</p>\n        <div class=\"grid md:grid-cols-3 gap-6 text-left mb-8\">\n          <div class=\"bg-slate-800/50 rounded-xl p-4\">\n            <div class=\"text-green-400 font-bold mb-1\">€1</div>\n            <div class=\"text-sm text-slate-400\">Sito base</div>\n            <div class=\"text-xs text-slate-500\">Landing semplice</div>\n          </div>\n          <div class=\"bg-slate-800/50 rounded-xl p-4 border border-purple-500/50\">\n            <div class=\"text-purple-400 font-bold mb-1\">€3</div>\n            <div class=\"text-sm text-slate-400\">Sito avanzato</div>\n            <div class=\"text-xs text-slate-500\">+ AI + chatbot</div>\n          </div>\n          <div class=\"bg-slate-800/50 rounded-xl p-4\">\n            <div class=\"text-pink-400 font-bold mb-1\">€5</div>\n            <div class=\"text-sm text-slate-400\">Pro</div>\n            <div class=\"text-xs text-slate-500\">Tutto incluso</div>\n          </div>\n        </div>\n        <ul class=\"text-left space-y-3 mb-8\">\n          <li class=\"flex items-center gap-3 text-slate-300\">\n            <i data-lucide=\"check\" class=\"w-5 h-5 text-green-400\"></i>\n            Crea il contenuto gratuitamente\n          </li>\n          <li class=\"flex items-center gap-3 text-slate-300\">\n            <i data-lucide=\"check\" class=\"w-5 h-5 text-green-400\"></i>\n            Vedi il prezzo prima di pagare\n          </li>\n          <li class=\"flex items-center gap-3 text-slate-300\">\n            <i data-lucide=\"check\" class=\"w-5 h-5 text-green-400\"></i>\n            Scarica ZIP o pubblica subito\n          </li>\n          <li class=\"flex items-center gap-3 text-slate-300\">\n            <i data-lucide=\"check\" class=\"w-5 h-5 text-green-400\"></i>\n            Torna a creare altre app quando vuoi\n          </li>\n        </ul>\n        <a href=\"#contact\" class=\"gradient-bg px-10 py-4 rounded-full font-bold text-lg hover:glow transition-all inline-flex items-center gap-2\">\n          <i data-lucide=\"sparkles\" class=\"w-5 h-5\"></i>\n          Prova Ora Gratis\n        </a>\n      </div>\n    </div>\n  </section>\n\n  <!-- White Label -->\n  <section id=\"whitelabel\" class=\"py-24 bg-slate-900/50\">\n    <div class=\"max-w-6xl mx-auto px-6\">\n      <div class=\"grid lg:grid-cols-2 gap-12 items-center\">\n        <div data-aos=\"fade-right\">\n          <div class=\"inline-flex items-center gap-2 glass px-4 py-2 rounded-full mb-6\">\n            <i data-lucide=\"badge-check\" class=\"w-4 h-4 text-purple-400\"></i>\n            <span class=\"text-sm\">White Label</span>\n          </div>\n          <h2 class=\"text-4xl font-bold mb-4\">La tua AI, il tuo brand</h2>\n          <p class=\"text-slate-400 mb-6\">\n            Personalizza PromptForge con i tuoi loghi, colori e contesto. Offri il servizio di AI app builder ai tuoi\n            clienti o nei tuoi eventi.\n          </p>\n          <ul class=\"space-y-4 mb-8\">\n            <li class=\"flex items-start gap-3\">\n              <i data-lucide=\"palette\" class=\"w-5 h-5 text-purple-400 mt-1\"></i>\n              <div>\n                <div class=\"font-semibold\">Brand personalizzato</div>\n                <div class=\"text-sm text-slate-400\">Logo, colori, font del tuo brand</div>\n              </div>\n            </li>\n            <li class=\"flex items-start gap-3\">\n              <i data-lucide=\"users\" class=\"w-5 h-5 text-purple-400 mt-1\"></i>\n              <div>\n                <div class=\"font-semibold\">Per i tuoi clienti</div>\n                <div class=\"text-sm text-slate-400\">Rivendi il servizio sotto il tuo nome</div>\n              </div>\n            </li>\n            <li class=\"flex items-start gap-3\">\n              <i data-lucide=\"tv\" class=\"w-5 h-5 text-purple-400 mt-1\"></i>\n              <div>\n                <div class=\"font-semibold\">Modalità Kiosk</div>\n                <div class=\"text-sm text-slate-400\">Perfetto per eventi e stand arcade</div>\n              </div>\n            </li>\n          </ul>\n          <a href=\"#contact\" class=\"inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 transition\">\n            Richiedi informazioni <i data-lucide=\"arrow-right\" class=\"w-4 h-4\"></i>\n          </a>\n        </div>\n        <div class=\"relative\" data-aos=\"fade-left\">\n          <div class=\"glass rounded-3xl p-6 glow\">\n            <div class=\"bg-slate-800 rounded-xl p-4 mb-4\">\n              <div class=\"flex items-center gap-3 mb-3\">\n                <div class=\"w-10 h-10 bg-gradient-to-r from-blue-500 to-cyan-500 rounded-lg\"></div>\n                <div>\n                  <div class=\"font-semibold\">Il TUO Brand</div>\n                  <div class=\"text-xs text-slate-400\">AI App Builder</div>\n                </div>\n              </div>\n              <div class=\"h-32 bg-slate-700/50 rounded-lg flex items-center justify-center\">\n                <i data-lucide=\"layout-template\" class=\"w-12 h-12 text-slate-500\"></i>\n              </div>\n            </div>\n            <div class=\"grid grid-cols-3 gap-3\">\n              <div class=\"bg-slate-800 rounded-lg p-3 text-center\">\n                <i data-lucide=\"zap\" class=\"w-5 h-5 mx-auto text-yellow-400 mb-1\"></i>\n                <div class=\"text-xs text-slate-400\">Fast</div