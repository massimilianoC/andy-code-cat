s=\"absolute top-full mt-2 left-1/2 -translate-x-1/2 w-72 glass rounded-2xl p-2 z-50\" data-pf-id=\"9aea26\">\n            <button @click=\"selected=&quot;Business Website&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center\" data-pf-id=\"1f596f\"><i data-lucide=\"briefcase\" class=\"w-5 h-5 text-blue-400\"></i></div>\n              <div data-pf-id=\"30f717\"><div class=\"font-medium\" data-pf-id=\"9b9bd6\">Business Website</div><div class=\"text-xs text-slate-400\" data-pf-id=\"531e0f\">Sito vetrina professionale</div></div>\n            </button>\n            <button @click=\"selected=&quot;Promo Landing&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-pink-500/20 rounded-lg flex items-center justify-center\" data-pf-id=\"9407e9\"><i data-lucide=\"megaphone\" class=\"w-5 h-5 text-pink-400\"></i></div>\n              <div data-pf-id=\"cffc16\"><div class=\"font-medium\" data-pf-id=\"c0ec1e\">Promo Landing</div><div class=\"text-xs text-slate-400\" data-pf-id=\"8f6be1\">Landing per campagne</div></div>\n            </button>\n            <button @click=\"selected=&quot;Casual Game&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center\" data-pf-id=\"8b1a7d\"><i data-lucide=\"gamepad-2\" class=\"w-5 h-5 text-green-400\"></i></div>\n              <div data-pf-id=\"566fb0\"><div class=\"font-medium\" data-pf-id=\"6ae012\">Casual Game</div><div class=\"text-xs text-slate-400\" data-pf-id=\"f9f6c1\">Mini gioco interattivo</div></div>\n            </button>\n            <button @click=\"selected=&quot;Branded Event&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-purple-500/20 rounded-lg flex items-center justify-center\" data-pf-id=\"956682\"><i data-lucide=\"calendar\" class=\"w-5 h-5 text-purple-400\"></i></div>\n              <div data-pf-id=\"daa45e\"><div class=\"font-medium\" data-pf-id=\"ba5a47\">Branded Event</div><div class=\"text-xs text-slate-400\" data-pf-id=\"2c80ed\">Sito per evento brandizzato</div></div>\n            </button>\n            <button @click=\"selected=&quot;Portfolio&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-orange-500/20 rounded-lg flex items-center justify-center\" data-pf-id=\"bcf008\"><i data-lucide=\"folder\" class=\"w-5 h-5 text-orange-400\"></i></div>\n              <div data-pf-id=\"d8b2cd\"><div class=\"font-medium\" data-pf-id=\"256349\">Portfolio</div><div class=\"text-xs text-slate-400\" data-pf-id=\"b9b994\">Mostra il tuo lavoro</div></div>\n            </button>\n            <button @click=\"selected=&quot;Restaurant&quot;; open=false\" class=\"w-full flex items-center gap-3 p-3 rounded-xl hover:bg-white/10 transition text-left\">\n              <div class=\"w-10 h-10 bg-cyan-500/20 rounded-lg flex items-center justify-center\" data-pf-id=\"4d345d\"><i data-lucide=\"utensils\" class=\"w-5 h-5 text-cyan-400\"></i></div>\n              <div data-pf-id=\"444fce\"><div class=\"font-medium\" data-pf-id=\"f2ecf3\">Restaurant</div><div class=\"text-xs text-slate-400\" data-pf-id=\"a280c4\">Menu e prenotazioni</div></div>\n            </button>\n          </div>\n        </div>\n      </div>\n      <div class=\"mt-16 flex items-center justify-center gap-8 text-slate-500\" data-pf-id=\"131e99\">\n        <div class=\"flex items-center gap-2\" data-pf-id=\"bd59b1\">\n          <i data-lucide=\"download\" class=\"w-5 h-5\"></i>\n          <span>Scarica ZIP</span>\n        </div>\n        <div class=\"flex items-center gap-2\" data-pf-id=\"bde298\">\n          <i data-lucide=\"edit-3\" class=\"w-5 h-5\"></i>\n          <span>WYSIWYG Editor</span>\n        </div>\n        <div class=\"flex items-center gap-2\" data-pf-id=\"a6e25f\">\n          <i data-lucide=\"euro\" class=\"w-5 h-5\"></i>\n          <span>1-5€ a app</span>\n        </div>\n      </div>\n    </div>\n    <!-- Floating cards -->\n    <div class=\"absolute top-1/4 left-10 glass rounded-2xl p-4 float hidden lg:block\" style=\"animation-delay: 0s;\" data-pf-id=\"c4cc2d\">\n      <div class=\"text-sm text-slate-400\" data-pf-id=\"7b2e5b\">Costo</div>\n      <div class=\"text-2xl font-bold text-green-400\" data-pf-id=\"fd0777\">€2.50</div>\n    </div>\n    <div class=\"absolute top-1/3 right-10 glass rounded-2xl p-4 float hidden lg:block\" style=\"animation-delay: 2s;\" data-pf-id=\"f591ac\">\n      <div class=\"text-sm text-slate-400\" data-pf-id=\"d0f9ee\">Template</div>\n      <div class=\"text-2xl font-bold text-purple-400\" data-pf-id=\"91be66\">One-Scroll</div>\n    </div>\n  </section>\n\n  <!-- How it works -->\n  <section id=\"how\" class=\"py-24 relative\" data-pf-id=\"50d67c\">\n    <div class=\"max-w-6xl mx-auto px-6\" data-pf-id=\"e4e918\">\n      <div class=\"text-center mb-16\" data-aos=\"fade-up\" data-pf-id=\"23bf8f\">\n        <h2 class=\"text-4xl font-bold mb-4\">Semplice come contare fino a 3</h2>\n        <p class=\"text-slate-400\">Il tuo sito pronto in tre mosse</p>\n      </div>\n      <div class=\"grid md:grid-cols-3 gap-8\" data-pf-id=\"0ff168\">\n        <div class=\"glass rounded-3xl p-8 text-center relative\" data-aos=\"fade-up\" data-aos-delay=\"100\" data-pf-id=\"dcfbbb\">\n          <div class=\"w-16 h-16 gradient-bg rounded-2xl flex items-center justify-center mx-auto mb-6\" data-pf-id=\"e19616\">\n            <i data-lucide=\"message-square\" class=\"w-8 h-8\"></i>\n          </div>\n          <div class=\"text-5xl font-bold gradient-text mb-2\" data-pf-id=\"cd1ec8\">1</div>\n          <h3 class=\"text-xl font-semibold mb-3\">Descrivi</h3>\n          <p class=\"text-slate-400\">Raconta cosa vuoi in linguaggio naturale. L'AI capisce e crea.</p>\n        </div>\n        <div class=\"glass rounded-3xl p-8 text-center relative\" data-aos=\"fade-up\" data-aos-delay=\"200\" data-pf-id=\"fb2277\">\n          <div class=\"w-16 h-16 gradient-bg rounded-2xl flex items-center justify-center mx-auto mb-6\" data-pf-id=\"63a016\">\n            <i data-lucide=\"eye\" class=\"w-8 h-8\"></i>\n          </div>\n          <div class=\"text-5xl font-bold gradient-text mb-2\" data-pf-id=\"fa7b8b\">2</div>\n          <h3 class=\"text-xl font-semibold mb-3\">Anteprima</h3>\n          <p class=\"text-slate-400\">Vedi il risultato in tempo reale. Modifica con l'editor WYSIWYG.</p>\n        </div>\n        <div class=\"glass rounded-3xl p-8 text-center relative\" data-aos=\"fade-up\" data-aos-delay=\"300\" data-pf-id=\"c553e1\">\n          <div class=\"w-16 h-16 gradient-bg rounded-2xl flex items-center justify-center mx-auto mb-6\" data-pf-id=\"dfc6aa\">\n            <i data-lucide=\"check-circle\" class=\"w-8 h-8\"></i>\n          </div>\n          <div class=\"text-5xl font-bold gradient-text mb-2\" data-pf-id=\"48e3cf\">3</div>\n          <h3 class=\"text-xl font-semibold mb-3\">Scarica</h3>\n          <p class=\"text-slate-400\">Se ti piace, scarica lo ZIP o pubblica. Solo 1-5€!</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Features -->\n  <section id=\"features\" class=\"py-24 bg-slate-900/50\" data-pf-id=\"301b96\">\n    <div class=\"max-w-6xl mx-auto px-6\" data-pf-id=\"854d6b\">\n      <div class=\"text-center mb-16\" data-aos=\"fade-up\" data-pf-id=\"50c98e\">\n        <h2 class=\"text-4xl font-bold mb-4\">Tutto quello che ti serve</h2>\n        <p class=\"text-slate-400\">Funzionalità AI avanzate in un'unica piattaforma</p>\n      </div>\n      <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-6\" data-pf-id=\"e88559\">\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"100\" data-pf-id=\"bcb48d\">\n          <div class=\"w-12 h-12 bg-purple-500/20 rounded-xl flex items-center justify-center mb-4\" data-pf-id=\"c0d99d\">\n            <i data-lucide=\"layout\" class=\"w-6 h-6 text-purple-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">One-Scroll Builder</h3>\n          <p class=\"text-slate-400 text-sm\">Landing page ottimizzate per conversione in un'unica pagina scorrevole.</p>\n        </div>\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"150\" data-pf-id=\"5bbce0\">\n          <div class=\"w-12 h-12 bg-pink-500/20 rounded-xl flex items-center justify-center mb-4\" data-pf-id=\"d6cc4c\">\n            <i data-lucide=\"image\" class=\"w-6 h-6 text-pink-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">AI Image Generator</h3>\n          <p class=\"text-slate-400 text-sm\">Genera immagini uniche con AI direttamente nel builder.</p>\n        </div>\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"200\" data-pf-id=\"d2c2ce\">\n          <div class=\"w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center mb-4\" data-pf-id=\"ee8a23\">\n            <i data-lucide=\"message-circle\" class=\"w-6 h-6 text-blue-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">AI Chatbot</h3>\n          <p class=\"text-slate-400 text-sm\">Integra un chatbot AI che risponde ai tuoi visitatori 24/7.</p>\n        </div>\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"250\" data-pf-id=\"fc2222\">\n          <div class=\"w-12 h-12 bg-green-500/20 rounded-xl flex items-center justify-center mb-4\" data-pf-id=\"a99ee4\">\n            <i data-lucide=\"edit-3\" class=\"w-6 h-6 text-green-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">WYSIWYG Editor</h3>\n          <p class=\"text-slate-400 text-sm\">Modifica ogni elemento visivamente. Drag &amp; drop semplice.</p>\n        </div>\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"300\" data-pf-id=\"a0bc7c\">\n          <div class=\"w-12 h-12 bg-orange-500/20 rounded-xl flex items-center justify-center mb-4\" data-pf-id=\"c914b3\">\n            <i data-lucide=\"code\" class=\"w-6 h-6 text-orange-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">Codice Pulito</h3>\n          <p class=\"text-slate-400 text-sm\">Scarica ZIP con sorgenti HTML/CSS/JS pronti per il deploy.</p>\n        </div>\n        <div class=\"glass rounded-2xl p-6 hover:bg-white/5 transition\" data-aos=\"fade-up\" data-aos-delay=\"350\" data-pf-id=\"116fe5\">\n          <div class=\"w-12 h-12 bg-cyan-500/20 rounded-xl flex items-center justify-center mb-4\" data-pf-id=\"415622\">\n            <i data-lucide=\"plug\" class=\"w-6 h-6 text-cyan-400\"></i>\n          </div>\n          <h3 class=\"text-lg font-semibold mb-2\">Integrazioni</h3>\n          <p class=\"text-slate-400 text-sm\">Collega analytics, email marketing, CRM e molto altro.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Pricing -->\n  <section id=\"pricing\" class=\"py-24 relative\" data-pf-id=\"a95f4f\">\n    <div class=\"max-w-4xl mx-auto px-6\" data-pf-id=\"4271c5\">\n      <div class=\"text-center mb-16\" data-aos=\"fade-up\" data-pf-id=\"d0fe4d\">\n        <h2 class=\"text-4xl font-bold mb-4\">Pay per use</h2>\n        <p class=\"text-slate-400\">Meno di un aperitivo per il tuo sito professionale</p>\n      </div>\n      <div class=\"glass rounded-3xl p-8 md:p-12 text-center glow\" data-aos=\"zoom-in\" data-pf-id=\"f5e2d2\">\n        <div class=\"inline-