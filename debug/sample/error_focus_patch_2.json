te-800 rounded-lg p-3 text-center'>\\n                <i data-lucide='zap' class='w-5 h-5 mx-auto text-yellow-400 mb-1'></i>\\n                <div class='text-xs text-slate-400'>Fast</div>\\n              </div>\\n              <div class='bg-slate-800 rounded-lg p-3 text-center'>\\n                <i data-lucide='shield' class='w-5 h-5 mx-auto text-green-400 mb-1'></i>\\n                <div class='text-xs text-slate-400'>Secure</div>\\n              </div>\\n              <div class='bg-slate-800 rounded-lg p-3 text-center'>\\n                <i data-lucide='globe' class='w-5 h-5 mx-auto text-blue-400 mb-1'></i>\\n                <div class='text-xs text-slate-400'>Global</div>\\n              </div>\\n            </div>\\n          </div>\\n        </div>\\n      </div>\\n    </div>\\n  </section>\\n\\n  <!-- Contact Form -->\\n  <section id='contact' class='py-24'>\\n    <div class='max-w-2xl mx-auto px-6'>\\n      <div class='text-center mb-12' data-aos='fade-up'>\\n        <h2 class='text-4xl font-bold mb-4'>Contattaci</h2>\\n        <p class='text-slate-400'>Hai domande? Scrivici e ti risponderemo subito</p>\\n      </div>\\n      <form class='glass rounded-3xl p-8' x-data=\\\"{ name: '', email: '', message: '', submitted: false }\\\" @submit.prevent='submitted=true' data-aos='fade-up'>\\n        <div class='space-y-6'>\\n          <div>\\n            <label class='block text-sm font-medium mb-2'>Nome</label>\\n            <input type='text' x-model='name' required class='w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 focus:outline-none focus:border-purple-500 transition' placeholder='Il tuo nome'>\\n          </div>\\n          <div>\\n            <label class='block text-sm font-medium mb-2'>Email</label>\\n            <input type='email' x-model='email' required class='w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 focus:outline-none focus:border-purple-500 transition' placeholder='tua@email.com'>\\n          </div>\\n 