{
  "name": "andy-code-cat",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/api",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",

    "_comment_local_dev": "--- LOCAL DEV (docker-compose.yml) — hot-reload, bind mounts ---",
    "local:dev": "docker compose up --build",
    "local:dev:up": "docker compose up --build -d",
    "local:dev:down": "docker compose down",
    "local:dev:logs": "docker compose logs -f --tail=100",
    "local:dev:restart:api": "docker compose up -d --no-deps api",

    "_comment_local_deploy": "--- LOCAL DEPLOY TEST (docker-compose.deploy.yml) — prod builds, named volumes ---",
    "local:up": "docker compose -f docker-compose.deploy.yml up -d",
    "local:down": "docker compose -f docker-compose.deploy.yml down",
    "local:build": "docker compose -f docker-compose.deploy.yml build",
    "local:build:nocache": "docker compose -f docker-compose.deploy.yml build --no-cache",
    "local:logs": "docker compose -f docker-compose.deploy.yml logs -f --tail=100",
    "local:logs:api": "docker compose -f docker-compose.deploy.yml logs -f --tail=200 api",
    "local:restart:api": "docker compose -f docker-compose.deploy.yml up -d --no-deps api",

    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "seed": "npm run seed -w apps/api",
    "seed:llm": "npm run seed:llm -w apps/api"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.28.0"
  }
}